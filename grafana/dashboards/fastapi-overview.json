      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_requests_total[5m])) by (path, status_code)",
          "legendFormat": "{{ path }} - {{ status_code }}",
          "instant": true,
          "refId": "A"
        }
